# Port the CSMS listens on (Railway sets PORT automatically; locally defaults to 9000)
PORT=9000

# PostgreSQL (Supabase) connection string — OPTIONAL.
# If set: persistence ON (chargers + transactions saved, survives redeploys).
# If unset: app runs fully in memory (charging still works, history not saved).
# Get it from Supabase: Project -> Connect -> ORM/"Connection string" (URI). Use the
# "Session"/"Transaction pooler" URI and put your DB password in it.
# DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
